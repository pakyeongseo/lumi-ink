{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-rose-court",
  "name": "로즈 코트",
  "description": "크림-로즈-골드의 사랑스러운 공주님 로그. 우아한 세리프와 금장 악센트.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(160deg,#fff8f2,#fbece2 60%,#f8e4d8)",
      "color": "#5c4750",
      "border": "1px solid #e8c9b8",
      "border-radius": "16px",
      "padding": "28px 26px",
      "box-shadow": "0 16px 42px rgba(180,120,130,.16), inset 0 0 0 1px rgba(208,168,108,.22)",
      "font-family": "Georgia,'Noto Serif KR','Nanum Myeongjo',serif",
      "line-height": "1.9",
      "max-width": "720px",
      "margin": "0 auto"
    },
    "header": {
      "color": "#c26a72",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".3em",
      "text-align": "center",
      "border-bottom": "1px solid #e3c08f",
      "padding": "0 0 15px",
      "margin": "0 0 20px"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 13px"
    },
    "empty": {
      "height": "12px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#bc3a5e",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#9a7fb0",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#a8823c",
        "border": "1px solid #e0c084",
        "border-radius": "8px",
        "padding": "1px 8px",
        "font-size": "13px",
        "letter-spacing": ".05em"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#9a2f48",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#b08894",
        "font-style": "italic"
      }
    },
    {
      "id": "dqq",
      "label": "큰따옴표 기호",
      "pattern": "\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#dc94a1"
      }
    },
    {
      "id": "sqq",
      "label": "작은따옴표 기호",
      "pattern": "'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#cab6ca"
      }
    }
  ],
  "persona": {
    "maskText": "그 분",
    "style": {
      "color": "#fffaf6",
      "background-color": "#cf9a6e",
      "border-radius": "999px",
      "padding": "1px 9px",
      "font-weight": "700",
      "letter-spacing": ".04em"
    }
  }
}