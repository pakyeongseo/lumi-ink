{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-plain-mono",
  "name": "플레인 모노",
  "description": "색을 비운 무채색 미니멀 로그. 건조한 서술과 절제된 강조.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background-color": "#fbfbfc",
      "color": "#2c2f34",
      "border": "1px solid #e1e3e7",
      "border-radius": "6px",
      "padding": "24px 22px",
      "box-shadow": "0 4px 16px rgba(40,44,52,.06)",
      "font-family": "-apple-system,BlinkMacSystemFont,'Noto Sans KR','Segoe UI',sans-serif",
      "line-height": "1.76",
      "max-width": "700px",
      "margin": "0 auto"
    },
    "header": {
      "color": "#8b9098",
      "font-size": "11px",
      "font-weight": "700",
      "letter-spacing": ".18em",
      "border-bottom": "1px solid #ececef",
      "padding": "0 0 12px",
      "margin": "0 0 16px"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 10px"
    },
    "empty": {
      "height": "9px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#14171b",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#6b7078",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(메모)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#73787f",
        "border": "1px solid #d6d9dd",
        "border-radius": "4px",
        "padding": "0 6px",
        "font-size": "13px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#000000",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#82878e",
        "font-style": "italic"
      }
    },
    {
      "id": "dqq",
      "label": "큰따옴표 기호",
      "pattern": "\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#88898c"
      }
    },
    {
      "id": "sqq",
      "label": "작은따옴표 기호",
      "pattern": "'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#b3b6ba"
      }
    }
  ],
  "persona": {
    "maskText": "○○",
    "style": {
      "color": "#fbfbfc",
      "background-color": "#4a4e55",
      "border-radius": "3px",
      "padding": "1px 7px",
      "font-weight": "700"
    }
  }
}