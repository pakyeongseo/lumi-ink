{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-carrot-patch",
  "name": "캐롯 패치",
  "description": "비비드 당근 오렌지와 싱싱한 잎 그린의 발랄 텃밭 로그.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(160deg,#fffaef,#fef2e0 55%,#f3f7e6)",
      "color": "#5c5238",
      "border": "1px solid #f0cf9c",
      "border-radius": "24px",
      "padding": "26px 24px",
      "box-shadow": "0 14px 36px rgba(220,160,70,.18)",
      "font-family": "-apple-system,BlinkMacSystemFont,'Noto Sans KR','Segoe UI',sans-serif",
      "line-height": "1.86",
      "max-width": "700px",
      "margin": "0 auto"
    },
    "header": {
      "color": "#e57a22",
      "font-size": "12px",
      "font-weight": "800",
      "letter-spacing": ".18em",
      "text-align": "center",
      "border-bottom": "2px dotted #f3d2a0",
      "padding": "0 0 13px",
      "margin": "0 0 17px"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#e0641a",
        "background-color": "rgba(250,190,120,.3)",
        "border-radius": "12px",
        "padding": "2px 10px",
        "font-weight": "800"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#5a9a3a",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#4a8a2e",
        "background-color": "rgba(170,210,120,.35)",
        "border-radius": "10px",
        "padding": "1px 8px",
        "font-size": "13px",
        "font-weight": "700"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#cf5212",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#6e9a44",
        "font-style": "italic"
      }
    },
    {
      "id": "sqq",
      "label": "작은따옴표 기호",
      "pattern": "'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#aac890"
      }
    }
  ],
  "persona": {
    "maskText": "그 친구",
    "style": {
      "color": "#fff",
      "background-color": "#f0822c",
      "border-radius": "999px",
      "padding": "1px 9px",
      "font-weight": "800"
    }
  }
}