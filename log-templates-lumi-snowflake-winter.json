{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-snowflake-winter",
  "name": "스노우플레이크 윈터",
  "description": "눈 화이트와 페일 아이스블루의 겨울 로그.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(165deg,#f8f9fd,#ecedf6 55%,#e6e6f2)",
      "color": "#4a5560",
      "border": "1px solid #cdddec",
      "border-radius": "16px",
      "padding": "28px 26px",
      "box-shadow": "0 14px 40px rgba(120,150,190,.16), inset 0 0 50px rgba(235,245,255,.5)",
      "font-family": "-apple-system,BlinkMacSystemFont,'Noto Sans KR','Segoe UI',sans-serif",
      "line-height": "1.88",
      "max-width": "720px",
      "margin": "0 auto"
    },
    "header": {
      "color": "#7a7ea8",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".3em",
      "text-align": "center",
      "border-bottom": "1px solid #d6e4f0",
      "padding": "0 0 14px",
      "margin": "0 0 18px"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 13px"
    },
    "empty": {
      "height": "12px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#4a5288",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#8a8ab0",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#5a86ae",
        "background-color": "rgba(180,210,235,.35)",
        "border-radius": "8px",
        "padding": "1px 8px",
        "font-size": "13px",
        "letter-spacing": ".04em",
        "box-shadow": "0 0 12px rgba(180,210,240,.4)"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#2a567e",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#7a8696",
        "font-style": "italic"
      }
    },
    {
      "id": "dqq",
      "label": "큰따옴표 기호",
      "pattern": "\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#9ca0c0"
      }
    },
    {
      "id": "sqq",
      "label": "작은따옴표 기호",
      "pattern": "'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#bcbcd4"
      }
    }
  ],
  "persona": {
    "maskText": "그 사람",
    "style": {
      "color": "#fff",
      "background-color": "#7ba4c8",
      "border-radius": "999px",
      "padding": "1px 9px",
      "font-weight": "700"
    }
  }
}