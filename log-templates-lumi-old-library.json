{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-old-library",
  "name": "올드 라이브러리",
  "description": "마호가니 서가와 가죽 장정의 도서관 로그.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(160deg,#22110c,#2c160e 55%,#24130d)",
      "color": "#c4ac8e",
      "border": "1px solid #5a4228",
      "border-left": "5px solid #2f4a32",
      "border-radius": "4px",
      "padding": "28px 26px",
      "box-shadow": "0 20px 48px rgba(0,0,0,.5), inset 0 0 60px rgba(90,60,28,.16)",
      "font-family": "Georgia,'Noto Serif KR','Nanum Myeongjo',serif",
      "line-height": "1.9",
      "max-width": "720px",
      "margin": "0 auto"
    },
    "header": {
      "color": "#a89150",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".3em",
      "border-bottom": "1px solid #5a4228",
      "padding": "0 0 15px",
      "margin": "0 0 20px"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 13px"
    },
    "empty": {
      "height": "12px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#cfd0aa",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#7a9a72",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#c89a4e",
        "border": "1px solid #7a5e30",
        "border-radius": "3px",
        "padding": "1px 8px",
        "font-size": "13px",
        "letter-spacing": ".05em"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#ddc488",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#9a8862",
        "font-style": "italic"
      }
    },
    {
      "id": "dqq",
      "label": "큰따옴표 기호",
      "pattern": "\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#7a725c"
      }
    },
    {
      "id": "sqq",
      "label": "작은따옴표 기호",
      "pattern": "'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#505640"
      }
    }
  ],
  "persona": {
    "maskText": "그 사람",
    "style": {
      "color": "#211410",
      "background-color": "#5e8a5a",
      "border-radius": "2px",
      "padding": "1px 8px",
      "font-weight": "700"
    }
  }
}