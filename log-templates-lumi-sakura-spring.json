{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-sakura-spring",
  "name": "사쿠라 스프링",
  "description": "벚꽃 분홍과 새순 연두의 봄 로그.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(165deg,#fffafc,#fceef3 55%,#f2f6ea)",
      "color": "#5e4f54",
      "border": "1px solid #f3cdd9",
      "border-radius": "16px",
      "padding": "26px 24px",
      "box-shadow": "0 14px 38px rgba(220,160,180,.16)",
      "font-family": "Georgia,'Noto Serif KR','Nanum Myeongjo',serif",
      "line-height": "1.88",
      "max-width": "700px",
      "margin": "0 auto"
    },
    "header": {
      "color": "#e07a9e",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".26em",
      "text-align": "center",
      "border-bottom": "1px solid #f6d6e0",
      "padding": "0 0 14px",
      "margin": "0 0 18px"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#d8517e",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#7fa84e",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#cf6f92",
        "background-color": "rgba(248,200,216,.4)",
        "border-radius": "10px",
        "padding": "1px 8px",
        "font-size": "13px",
        "letter-spacing": ".03em"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#b83a64",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#6e9648",
        "font-style": "italic"
      }
    },
    {
      "id": "dqq",
      "label": "큰따옴표 기호",
      "pattern": "\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#e8a2b8"
      }
    },
    {
      "id": "sqq",
      "label": "작은따옴표 기호",
      "pattern": "'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#bccea0"
      }
    }
  ],
  "persona": {
    "maskText": "그 애",
    "style": {
      "color": "#fff",
      "background-color": "#ee8aac",
      "border-radius": "999px",
      "padding": "1px 9px",
      "font-weight": "700"
    }
  }
}