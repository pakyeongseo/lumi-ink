{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-rewind-thread",
  "name": "리와인드 스레드",
  "description": "청록-골드 톤의 빙의·회귀물 로그. 회차 표기와 운명의 실 무드.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(160deg,#0a1f23,#0f282d 55%,#0c2226)",
      "color": "#c4d3da",
      "border": "1px solid #2a585e",
      "border-radius": "8px",
      "padding": "28px 26px",
      "box-shadow": "0 20px 48px rgba(4,12,18,.5), inset 0 0 0 1px rgba(196,168,96,.14)",
      "font-family": "Georgia,'Noto Serif KR','Nanum Myeongjo',serif",
      "line-height": "1.9",
      "max-width": "720px",
      "margin": "0 auto"
    },
    "header": {
      "color": "#cdb273",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".32em",
      "border-bottom": "1px solid #2c4a52",
      "padding": "0 0 15px",
      "margin": "0 0 20px"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 13px"
    },
    "empty": {
      "height": "12px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#6fd2d8",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(전생의 기억)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#a99bc4",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(회차·시점)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#1a2730",
        "background-color": "#c7a85c",
        "border-radius": "3px",
        "padding": "1px 8px",
        "font-size": "13px",
        "font-weight": "700",
        "letter-spacing": ".06em"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#e8eef0",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#8fa6ad",
        "font-style": "italic"
      }
    },
    {
      "id": "dqq",
      "label": "큰따옴표 기호",
      "pattern": "\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#3e7a80"
      }
    },
    {
      "id": "sqq",
      "label": "작은따옴표 기호",
      "pattern": "'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#5a5f76"
      }
    }
  ],
  "persona": {
    "maskText": "그 사람",
    "style": {
      "color": "#0e1a22",
      "background-color": "#5fb8bf",
      "border-radius": "3px",
      "padding": "1px 8px",
      "font-weight": "700",
      "letter-spacing": ".04em"
    }
  }
}