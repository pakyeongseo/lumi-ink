{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-crt-terminal",
  "name": "CRT 터미널",
  "description": "검은 화면에 인광 그린이 번지는 80년대 CRT 터미널 로그. 모노크롬 도스 무드.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "#020806",
      "line-height": "1.72",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#3aff8a",
      "border": "1px solid #0e3a22",
      "border-radius": "4px",
      "padding": "26px",
      "box-shadow": "inset 0 0 50px rgba(58,255,138,.08), 0 16px 40px rgba(0,4,2,.5)",
      "font-family": "'Space Mono','SFMono-Regular',Consolas,'D2Coding',monospace"
    },
    "header": {
      "color": "#6affa0",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".2em",
      "text-shadow": "0 0 10px rgba(58,255,138,.5)",
      "padding": "0 0 12px",
      "margin": "0 0 16px",
      "border-bottom": "1px solid #134a2a"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#9affc0",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#2aa868",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#6affa0",
        "border": "1px solid #1e6a3e",
        "border-radius": "2px",
        "padding": "1px 6px",
        "font-size": "13px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#d0ffe0",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#3ac878",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": ">_익명",
    "style": {
      "color": "#020806",
      "background-color": "#3aff8a",
      "border-radius": "2px",
      "padding": "1px 8px",
      "font-weight": "700"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#020806",
          "background-color": "#3aff8a",
          "border-radius": "2px",
          "padding": "1px 8px",
          "font-weight": "700"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#3aff8a",
          "background-color": "transparent",
          "border": "1.5px solid rgba(58,255,138,0.85)",
          "border-radius": "2px",
          "padding": "0 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#3aff8a",
          "border-bottom": "2px solid rgba(58,255,138,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "700"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#3aff8a",
          "background-color": "rgba(58,255,138,0.22)",
          "border-radius": "2px",
          "padding": "1px 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#3aff8a",
          "background": "linear-gradient(to top, rgba(58,255,138,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "700"
        }
      }
    ]
  }
}