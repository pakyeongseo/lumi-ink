{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-volcanic",
  "name": "화산 마그마",
  "description": "흑요석 균열 사이로 흐르는 용암의 로그. 붉게 타오르는 화산 무드.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(165deg,#2a1410,#1a0c08)",
      "line-height": "1.78",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#e8c0a8",
      "border": "1px solid #5a2a1a",
      "border-radius": "8px",
      "padding": "28px",
      "box-shadow": "inset 0 -30px 70px rgba(255,106,42,.12), 0 16px 42px rgba(10,4,2,.5)",
      "font-family": "-apple-system,BlinkMacSystemFont,'Noto Sans KR',sans-serif"
    },
    "header": {
      "color": "#ff8a4a",
      "font-size": "12px",
      "font-weight": "800",
      "letter-spacing": ".18em",
      "padding": "0 0 12px",
      "margin": "0 0 16px",
      "text-shadow": "0 0 14px rgba(255,106,42,.45)",
      "border-bottom": "1px solid #4a221a"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#ffaa6a",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#b08470",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#ffaa3a",
        "border": "1px solid #8a4a22",
        "border-radius": "3px",
        "padding": "1px 7px",
        "font-size": "13px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#ffe0c8",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#c89880",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "•분화구•",
    "style": {
      "color": "#1a0c08",
      "background-color": "#ff6a2a",
      "border-radius": "3px",
      "padding": "1px 9px",
      "font-weight": "800"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#1a0c08",
          "background-color": "#ff6a2a",
          "border-radius": "3px",
          "padding": "1px 9px",
          "font-weight": "800"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#ffbc9f",
          "background-color": "transparent",
          "border": "1.5px solid rgba(255,106,42,0.85)",
          "border-radius": "3px",
          "padding": "0 7px",
          "font-weight": "800"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#ffbc9f",
          "border-bottom": "2px solid rgba(255,106,42,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "800"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#ffbc9f",
          "background-color": "rgba(255,106,42,0.22)",
          "border-radius": "3px",
          "padding": "1px 7px",
          "font-weight": "800"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#ffbc9f",
          "background": "linear-gradient(to top, rgba(255,106,42,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "800"
        }
      }
    ]
  }
}