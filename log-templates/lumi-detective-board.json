{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-detective-board",
  "name": "추리 보드",
  "description": "코르크판에 붉은 실로 엮인 단서들의 수사 로그. 사건을 쫓는 탐정 무드.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(160deg,#3a3026,#2a221a)",
      "line-height": "1.74",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#e0d4bc",
      "border": "1px solid #5a4a36",
      "border-radius": "6px",
      "padding": "28px",
      "box-shadow": "inset 0 0 60px rgba(0,0,0,.25), 0 16px 40px rgba(8,6,2,.45)",
      "font-family": "'Space Mono','SFMono-Regular',Consolas,'D2Coding',monospace"
    },
    "header": {
      "color": "#c8a860",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".18em",
      "padding": "0 0 12px",
      "margin": "0 0 16px",
      "text-transform": "uppercase",
      "border-bottom": "1px dashed #5a4a36"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#e8a860",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#9a8a6a",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#d05a48",
        "border": "1px solid #8a4438",
        "border-radius": "2px",
        "padding": "1px 7px",
        "font-size": "13px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#f0e0c0",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#b0a080",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "용의자?",
    "style": {
      "color": "#2a221a",
      "background-color": "#c04030",
      "border-radius": "2px",
      "padding": "1px 9px",
      "font-weight": "700"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#2a221a",
          "background-color": "#c04030",
          "border-radius": "2px",
          "padding": "1px 9px",
          "font-weight": "700"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#e3a9a2",
          "background-color": "transparent",
          "border": "1.5px solid rgba(192,64,48,0.85)",
          "border-radius": "2px",
          "padding": "0 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#e3a9a2",
          "border-bottom": "2px solid rgba(192,64,48,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "700"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#e3a9a2",
          "background-color": "rgba(192,64,48,0.22)",
          "border-radius": "2px",
          "padding": "1px 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#e3a9a2",
          "background": "linear-gradient(to top, rgba(192,64,48,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "700"
        }
      }
    ]
  }
}