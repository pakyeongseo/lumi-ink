{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-film-noir",
  "name": "필름 누아르",
  "description": "흑백 시네마의 모노크롬 로그. 고전 누아르 영화의 음영과 정적.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(170deg,#1a1a1a,#0e0e0e)",
      "line-height": "1.78",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#d8d8d8",
      "border": "1px solid #3a3a3a",
      "border-radius": "2px",
      "padding": "26px",
      "box-shadow": "0 16px 44px rgba(0,0,0,.55)",
      "font-family": "Georgia,'Noto Serif KR','Nanum Myeongjo',serif"
    },
    "header": {
      "color": "#f0f0f0",
      "font-size": "13px",
      "font-weight": "700",
      "font-style": "italic",
      "letter-spacing": ".16em",
      "border-bottom": "1px solid #4a4a4a",
      "padding": "0 0 12px",
      "margin": "0 0 17px"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#ffffff",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#989898",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#cacaca",
        "border": "1px solid #5a5a5a",
        "border-radius": "2px",
        "padding": "1px 7px",
        "font-size": "13px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#ffffff",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#b0b0b0",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "无名",
    "style": {
      "color": "#1a1a1a",
      "background-color": "#e8e8e8",
      "border-radius": "2px",
      "padding": "1px 8px",
      "font-weight": "700"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#1a1a1a",
          "background-color": "#e8e8e8",
          "border-radius": "2px",
          "padding": "1px 8px",
          "font-weight": "700"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#e8e8e8",
          "background-color": "transparent",
          "border": "1.5px solid rgba(232,232,232,0.85)",
          "border-radius": "2px",
          "padding": "0 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#e8e8e8",
          "border-bottom": "2px solid rgba(232,232,232,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "700"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#e8e8e8",
          "background-color": "rgba(232,232,232,0.22)",
          "border-radius": "2px",
          "padding": "1px 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#e8e8e8",
          "background": "linear-gradient(to top, rgba(232,232,232,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "700"
        }
      }
    ]
  }
}