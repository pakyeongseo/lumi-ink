{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-vintage-circus",
  "name": "빈티지 서커스",
  "description": "진홍 천막과 금장식의 카니발 로그. 막이 오르는 서커스의 화려한 무드.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(165deg,#3a1018,#2a0a12)",
      "line-height": "1.78",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#f0d8c0",
      "border": "2px solid #c8902a",
      "border-radius": "10px",
      "padding": "28px",
      "box-shadow": "inset 0 0 0 1px rgba(232,176,58,.15), 0 16px 44px rgba(12,2,6,.5)",
      "font-family": "Georgia,'Noto Serif KR','Nanum Myeongjo',serif"
    },
    "header": {
      "color": "#e8b03a",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".22em",
      "padding": "0 0 12px",
      "margin": "0 0 16px",
      "text-align": "center",
      "border-bottom": "1px solid #6a3028"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#f0a0a8",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#b08878",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#e8b03a",
        "border": "1px solid #a87f2a",
        "border-radius": "4px",
        "padding": "1px 7px",
        "font-size": "13px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#f8e0b0",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#c8a090",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "★관객★",
    "style": {
      "color": "#2a0a12",
      "background-color": "#e8b03a",
      "border-radius": "4px",
      "padding": "1px 9px",
      "font-weight": "700"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#2a0a12",
          "background-color": "#e8b03a",
          "border-radius": "4px",
          "padding": "1px 9px",
          "font-weight": "700"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#e8b03a",
          "background-color": "transparent",
          "border": "1.5px solid rgba(232,176,58,0.85)",
          "border-radius": "4px",
          "padding": "0 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#e8b03a",
          "border-bottom": "2px solid rgba(232,176,58,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "700"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#e8b03a",
          "background-color": "rgba(232,176,58,0.22)",
          "border-radius": "4px",
          "padding": "1px 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#e8b03a",
          "background": "linear-gradient(to top, rgba(232,176,58,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "700"
        }
      }
    ]
  }
}