{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-concerto-stage",
  "name": "콘체르토 스테이지",
  "description": "버건디 무대와 샴페인 골드의 음악 연주 로그. 네이비 왕실 격식과 달리 따뜻한 무대 예술 톤.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(160deg,#26121a,#301622 55%,#28131c)",
      "color": "#d8c2c0",
      "border": "1px solid #b08a4a",
      "border-radius": "8px",
      "padding": "28px 26px",
      "box-shadow": "0 20px 48px rgba(12,4,8,.55), inset 0 0 60px rgba(120,40,60,.16)",
      "font-family": "Georgia,'Noto Serif KR','Nanum Myeongjo',serif",
      "line-height": "1.9",
      "max-width": "720px",
      "margin": "0 auto"
    },
    "header": {
      "color": "#e3c878",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".32em",
      "text-align": "center",
      "border-bottom": "1px solid #6e5a30",
      "padding": "0 0 15px",
      "margin": "0 0 20px"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 13px"
    },
    "empty": {
      "height": "12px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#f0e2cc",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#d49aa6",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(악장·음악)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#e3c878",
        "border": "1px solid #8a6e38",
        "border-radius": "6px",
        "padding": "1px 8px",
        "font-size": "13px",
        "letter-spacing": ".05em"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#edd388",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#c8a0aa",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "그 사람",
    "style": {
      "color": "#26121a",
      "background-color": "#e3c878",
      "border-radius": "999px",
      "padding": "1px 9px",
      "font-weight": "700"
    }
  }
}