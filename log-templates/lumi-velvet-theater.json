{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-velvet-theater",
  "name": "벨벳 극장",
  "description": "진홍 벨벳 커튼과 금장식의 극장 로그. 막이 오르는 무대의 장중한 무드.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(165deg,#2a0e14,#1e0a10)",
      "line-height": "1.78",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#e8d0c0",
      "border": "1px solid #5a2a30",
      "border-radius": "8px",
      "padding": "28px",
      "box-shadow": "inset 0 0 0 1px rgba(212,168,56,.2), 0 16px 44px rgba(10,2,4,.5)",
      "font-family": "Georgia,'Noto Serif KR','Nanum Myeongjo',serif"
    },
    "header": {
      "color": "#d4a838",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".26em",
      "text-align": "center",
      "border-bottom": "1px solid #5a2a30",
      "padding": "0 0 14px",
      "margin": "0 0 18px"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#e8a8b0",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#b08878",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#d4a838",
        "border": "1px solid #a87f2a",
        "border-radius": "4px",
        "padding": "1px 7px",
        "font-size": "13px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#f0d8a0",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#c0a090",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "관객",
    "style": {
      "color": "#1e0a10",
      "background-color": "#d4a838",
      "border-radius": "4px",
      "padding": "1px 9px",
      "font-weight": "700"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#1e0a10",
          "background-color": "#d4a838",
          "border-radius": "4px",
          "padding": "1px 9px",
          "font-weight": "700"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#d4a838",
          "background-color": "transparent",
          "border": "1.5px solid rgba(212,168,56,0.85)",
          "border-radius": "4px",
          "padding": "0 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#d4a838",
          "border-bottom": "2px solid rgba(212,168,56,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "700"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#d4a838",
          "background-color": "rgba(212,168,56,0.22)",
          "border-radius": "4px",
          "padding": "1px 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#d4a838",
          "background": "linear-gradient(to top, rgba(212,168,56,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "700"
        }
      }
    ]
  }
}