{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-dragon-lair",
  "name": "드래곤 둥지",
  "description": "비늘 금빛과 에메랄드, 불씨의 용 둥지 로그. 보물 위에 잠든 드래곤 무드.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(165deg,#16201a,#0e1610)",
      "line-height": "1.78",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#cad8c8",
      "border": "1px solid #2e4232",
      "border-radius": "8px",
      "padding": "28px",
      "box-shadow": "inset 0 0 50px rgba(212,168,56,.08), 0 16px 42px rgba(4,10,6,.5)",
      "font-family": "Georgia,'Noto Serif KR','Nanum Myeongjo',serif"
    },
    "header": {
      "color": "#d4a838",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".2em",
      "padding": "0 0 12px",
      "margin": "0 0 16px",
      "border-bottom": "1px solid #2e4232"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#5ac06a",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#8aa888",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#e8602a",
        "border": "1px solid #8a4422",
        "border-radius": "3px",
        "padding": "1px 7px",
        "font-size": "13px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#f0d890",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#9ab098",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "침입자",
    "style": {
      "color": "#0e1610",
      "background-color": "#d4a838",
      "border-radius": "3px",
      "padding": "1px 9px",
      "font-weight": "700"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#0e1610",
          "background-color": "#d4a838",
          "border-radius": "3px",
          "padding": "1px 9px",
          "font-weight": "700"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#d4a838",
          "background-color": "transparent",
          "border": "1.5px solid rgba(212,168,56,0.85)",
          "border-radius": "3px",
          "padding": "0 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#d4a838",
          "border-bottom": "2px solid rgba(212,168,56,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "700"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#d4a838",
          "background-color": "rgba(212,168,56,0.22)",
          "border-radius": "3px",
          "padding": "1px 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#d4a838",
          "background": "linear-gradient(to top, rgba(212,168,56,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "700"
        }
      }
    ]
  }
}