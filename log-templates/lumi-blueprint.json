{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-blueprint",
  "name": "블루프린트",
  "description": "청사진 그리드 위의 설계도 로그. 시안 라인과 모노 타이포의 공학적 무드.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(135deg,#0d2236,#0a1a2b)",
      "line-height": "1.78",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#cfe6ff",
      "border": "1px solid #2d5a82",
      "border-radius": "6px",
      "padding": "24px",
      "box-shadow": "inset 0 0 60px rgba(36,108,168,.10), 0 14px 36px rgba(4,12,24,.4)",
      "font-family": "'Space Mono','SFMono-Regular',Consolas,'D2Coding',monospace"
    },
    "header": {
      "color": "#6fd3ff",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".26em",
      "border-bottom": "1px dashed #2f5f86",
      "padding": "0 0 12px",
      "margin": "0 0 16px",
      "text-transform": "uppercase"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#aee0ff",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#6f9fc0",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#5cc6ff",
        "border": "1px solid #3a86b8",
        "border-radius": "3px",
        "padding": "1px 6px",
        "font-size": "13px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#ffffff",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#8fb8d8",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "[기밀]",
    "style": {
      "color": "#07243a",
      "background-color": "#5cc6ff",
      "border-radius": "3px",
      "padding": "1px 8px",
      "font-weight": "700",
      "letter-spacing": ".06em"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#07243a",
          "background-color": "#5cc6ff",
          "border-radius": "3px",
          "padding": "1px 8px",
          "font-weight": "700",
          "letter-spacing": ".06em"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#5cc6ff",
          "background-color": "transparent",
          "border": "1.5px solid rgba(92,198,255,0.85)",
          "border-radius": "3px",
          "padding": "0 7px",
          "font-weight": "700",
          "letter-spacing": ".06em"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#5cc6ff",
          "border-bottom": "2px solid rgba(92,198,255,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "700",
          "letter-spacing": ".06em"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#5cc6ff",
          "background-color": "rgba(92,198,255,0.22)",
          "border-radius": "3px",
          "padding": "1px 7px",
          "font-weight": "700",
          "letter-spacing": ".06em"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#5cc6ff",
          "background": "linear-gradient(to top, rgba(92,198,255,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "700",
          "letter-spacing": ".06em"
        }
      }
    ]
  }
}