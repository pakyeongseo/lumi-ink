{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-graffiti",
  "name": "그래피티",
  "description": "콘크리트 벽에 스프레이로 휘갈긴 스트리트 로그. 형광 태그의 도시 힙합 무드.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(160deg,#2a2a2e,#1e1e22)",
      "line-height": "1.78",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#d8d8d0",
      "border": "1px solid #3e3e44",
      "border-radius": "4px",
      "padding": "26px",
      "box-shadow": "inset 0 0 60px rgba(0,0,0,.3), 0 16px 40px rgba(0,0,0,.4)",
      "font-family": "-apple-system,BlinkMacSystemFont,'Noto Sans KR',sans-serif"
    },
    "header": {
      "color": "#ffd23a",
      "font-size": "13px",
      "font-weight": "800",
      "letter-spacing": ".1em",
      "text-transform": "uppercase",
      "text-shadow": "2px 2px 0 rgba(255,58,138,.5)",
      "padding": "0 0 12px",
      "margin": "0 0 16px",
      "border-bottom": "2px solid #3e3e44"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#3affc0",
        "font-weight": "800"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#ff7aa8",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#ff3a8a",
        "border": "2px solid #ff3a8a",
        "border-radius": "3px",
        "padding": "0 7px",
        "font-weight": "700",
        "font-size": "13px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#ffe23a",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#9a9a92",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "[TAG]",
    "style": {
      "color": "#1e1e22",
      "background-color": "#ffd23a",
      "border-radius": "3px",
      "padding": "1px 9px",
      "font-weight": "800"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#1e1e22",
          "background-color": "#ffd23a",
          "border-radius": "3px",
          "padding": "1px 9px",
          "font-weight": "800"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#ffd23a",
          "background-color": "transparent",
          "border": "1.5px solid rgba(255,210,58,0.85)",
          "border-radius": "3px",
          "padding": "0 7px",
          "font-weight": "800"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#ffd23a",
          "border-bottom": "2px solid rgba(255,210,58,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "800"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#ffd23a",
          "background-color": "rgba(255,210,58,0.22)",
          "border-radius": "3px",
          "padding": "1px 7px",
          "font-weight": "800"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#ffd23a",
          "background": "linear-gradient(to top, rgba(255,210,58,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "800"
        }
      }
    ]
  }
}