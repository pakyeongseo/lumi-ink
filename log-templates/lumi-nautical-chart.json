{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-nautical-chart",
  "name": "항해 해도",
  "description": "세피아 해도와 나침반의 대항해 로그. 빛바랜 양피지 지도 위의 모험 무드.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(160deg,#e6dcc4,#dcd0b4)",
      "line-height": "1.78",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#2e3a3a",
      "border": "1px solid #c0b48c",
      "border-radius": "5px",
      "padding": "28px",
      "box-shadow": "inset 0 0 60px rgba(140,110,60,.1), 0 12px 32px rgba(110,90,50,.16)",
      "font-family": "Georgia,'Noto Serif KR','Nanum Myeongjo',serif"
    },
    "header": {
      "color": "#2a6a7a",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".2em",
      "border-bottom": "2px solid #c0a878",
      "padding": "0 0 12px",
      "margin": "0 0 16px"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#1f5260",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#7a6a4a",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#8a4a2a",
        "border": "1px solid #c0a070",
        "border-radius": "3px",
        "padding": "1px 7px",
        "font-size": "13px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#1e2a2a",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#6a7058",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "항해사",
    "style": {
      "color": "#e8dec6",
      "background-color": "#2a6a7a",
      "border-radius": "3px",
      "padding": "1px 9px",
      "font-weight": "700"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#e8dec6",
          "background-color": "#2a6a7a",
          "border-radius": "3px",
          "padding": "1px 9px",
          "font-weight": "700"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#2a6a7a",
          "background-color": "transparent",
          "border": "1.5px solid rgba(42,106,122,0.85)",
          "border-radius": "3px",
          "padding": "0 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#2a6a7a",
          "border-bottom": "2px solid rgba(42,106,122,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "700"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#2a6a7a",
          "background-color": "rgba(42,106,122,0.16)",
          "border-radius": "3px",
          "padding": "1px 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#2a6a7a",
          "background": "linear-gradient(to top, rgba(42,106,122,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "700"
        }
      }
    ]
  }
}