{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-crystal-cave",
  "name": "수정 동굴",
  "description": "자수정과 청록 크리스탈이 발광하는 동굴 로그. 광맥의 신비로운 빛.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "radial-gradient(120% 100% at 50% 20%,#1a1438,#0e0a22 76%)",
      "line-height": "1.78",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#d0c8e8",
      "border": "1px solid #2e2452",
      "border-radius": "14px",
      "padding": "26px",
      "box-shadow": "inset 0 0 60px rgba(176,106,255,.1), 0 16px 44px rgba(4,2,14,.5)",
      "font-family": "-apple-system,BlinkMacSystemFont,'Noto Sans KR',sans-serif"
    },
    "header": {
      "color": "#b06aff",
      "font-size": "12px",
      "font-weight": "800",
      "letter-spacing": ".18em",
      "padding": "0 0 12px",
      "margin": "0 0 16px",
      "text-shadow": "0 0 14px rgba(74,208,224,.4)",
      "border-bottom": "1px solid #2e2452"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#c8a0ff",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#4ad0e0",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#4ad0e0",
        "background-color": "rgba(74,208,224,.13)",
        "border-radius": "8px",
        "padding": "1px 7px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#ecdcff",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#a0c8d8",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "○광맥○",
    "style": {
      "color": "#0e0a22",
      "background-color": "#b06aff",
      "border-radius": "999px",
      "padding": "1px 9px",
      "font-weight": "800"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#0e0a22",
          "background-color": "#b06aff",
          "border-radius": "999px",
          "padding": "1px 9px",
          "font-weight": "800"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#dbbcff",
          "background-color": "transparent",
          "border": "1.5px solid rgba(176,106,255,0.85)",
          "border-radius": "999px",
          "padding": "0 7px",
          "font-weight": "800"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#dbbcff",
          "border-bottom": "2px solid rgba(176,106,255,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "800"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#dbbcff",
          "background-color": "rgba(176,106,255,0.22)",
          "border-radius": "7px",
          "padding": "1px 7px",
          "font-weight": "800"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#dbbcff",
          "background": "linear-gradient(to top, rgba(176,106,255,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "800"
        }
      }
    ]
  }
}