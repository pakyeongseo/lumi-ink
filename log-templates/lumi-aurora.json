{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-aurora",
  "name": "오로라",
  "description": "청록과 자주의 극광이 흐르는 밤하늘 로그. 차가운 북극의 신비로운 빛.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(180deg,#0a1424,#10243a 50%,#0e2030)",
      "line-height": "1.78",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#cfe0e8",
      "border": "1px solid #1e3a52",
      "border-radius": "14px",
      "padding": "26px",
      "box-shadow": "inset 0 40px 80px rgba(78,224,176,.08), 0 16px 42px rgba(2,10,18,.5)",
      "font-family": "-apple-system,BlinkMacSystemFont,'Noto Sans KR',sans-serif"
    },
    "header": {
      "color": "#4ee0b0",
      "font-size": "12px",
      "font-weight": "800",
      "letter-spacing": ".18em",
      "text-shadow": "0 0 14px rgba(78,224,176,.45)",
      "padding": "0 0 12px",
      "margin": "0 0 16px",
      "border-bottom": "1px solid #1e3a52"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#8af0d0",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#a86ad0",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#4ee0b0",
        "background-color": "rgba(78,224,176,.12)",
        "border-radius": "6px",
        "padding": "1px 7px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#d8fff0",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#c0a0e0",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "•여행자•",
    "style": {
      "color": "#08161a",
      "background-color": "#4ee0b0",
      "border-radius": "999px",
      "padding": "1px 9px",
      "font-weight": "800"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#08161a",
          "background-color": "#4ee0b0",
          "border-radius": "999px",
          "padding": "1px 9px",
          "font-weight": "800"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#4ee0b0",
          "background-color": "transparent",
          "border": "1.5px solid rgba(78,224,176,0.85)",
          "border-radius": "999px",
          "padding": "0 7px",
          "font-weight": "800"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#4ee0b0",
          "border-bottom": "2px solid rgba(78,224,176,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "800"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#4ee0b0",
          "background-color": "rgba(78,224,176,0.22)",
          "border-radius": "7px",
          "padding": "1px 7px",
          "font-weight": "800"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#4ee0b0",
          "background": "linear-gradient(to top, rgba(78,224,176,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "800"
        }
      }
    ]
  }
}