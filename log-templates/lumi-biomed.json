{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-biomed",
  "name": "바이오메드",
  "description": "청록 홀로그램과 화이트 데이터의 미래 의료 로그. 무기질 바이오 SF 무드.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(160deg,#0e1a20,#0a141a)",
      "line-height": "1.78",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#c0d8e0",
      "border": "1px solid #1e4452",
      "border-radius": "6px",
      "padding": "26px",
      "box-shadow": "inset 0 0 0 1px rgba(42,208,200,.12), 0 16px 42px rgba(2,10,14,.5)",
      "font-family": "-apple-system,BlinkMacSystemFont,'Noto Sans KR',sans-serif"
    },
    "header": {
      "color": "#2ad0c8",
      "font-size": "12px",
      "font-weight": "800",
      "letter-spacing": ".2em",
      "text-transform": "uppercase",
      "text-shadow": "0 0 12px rgba(42,208,200,.4)",
      "padding": "0 0 12px",
      "margin": "0 0 16px",
      "border-bottom": "1px solid #1e4452"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#6ae0d8",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#5a9ad8",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#5a9ad8",
        "border": "1px solid #2a5a72",
        "border-radius": "3px",
        "padding": "1px 7px",
        "font-size": "13px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#d0f4f0",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#8ab0c8",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "[ID:████]",
    "style": {
      "color": "#04161a",
      "background-color": "#2ad0c8",
      "border-radius": "3px",
      "padding": "1px 8px",
      "font-weight": "800"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#04161a",
          "background-color": "#2ad0c8",
          "border-radius": "3px",
          "padding": "1px 8px",
          "font-weight": "800"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#2ad0c8",
          "background-color": "transparent",
          "border": "1.5px solid rgba(42,208,200,0.85)",
          "border-radius": "3px",
          "padding": "0 7px",
          "font-weight": "800"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#2ad0c8",
          "border-bottom": "2px solid rgba(42,208,200,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "800"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#2ad0c8",
          "background-color": "rgba(42,208,200,0.22)",
          "border-radius": "3px",
          "padding": "1px 7px",
          "font-weight": "800"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#2ad0c8",
          "background": "linear-gradient(to top, rgba(42,208,200,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "800"
        }
      }
    ]
  }
}