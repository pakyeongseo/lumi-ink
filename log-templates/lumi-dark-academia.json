{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-dark-academia",
  "name": "다크 아카데미아",
  "description": "버건디와 앤티크 골드의 음울한 학구열. 고전 세리프의 어두운 서재 무드.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(160deg,#2a211c,#1f1813)",
      "line-height": "1.85",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#d8c7af",
      "border": "1px solid #4a3a2c",
      "border-radius": "4px",
      "padding": "30px 28px",
      "box-shadow": "0 16px 40px rgba(10,6,2,.4)",
      "font-family": "Georgia,'Noto Serif KR','Nanum Myeongjo',serif"
    },
    "header": {
      "color": "#c89a5a",
      "font-size": "13px",
      "font-weight": "700",
      "font-style": "italic",
      "letter-spacing": ".1em",
      "border-bottom": "3px double #5a4632",
      "padding": "0 0 13px",
      "margin": "0 0 18px"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#d4a574",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#9a8a6a",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#a85050",
        "border": "1px solid #6a3838",
        "border-radius": "3px",
        "padding": "1px 7px",
        "font-size": "13px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#e8d4b0",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#a89878",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "익명",
    "style": {
      "color": "#f0e0c8",
      "background-color": "#8a3a3a",
      "border-radius": "3px",
      "padding": "1px 8px",
      "font-weight": "700"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#f0e0c8",
          "background-color": "#8a3a3a",
          "border-radius": "3px",
          "padding": "1px 8px",
          "font-weight": "700"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#caa6a6",
          "background-color": "transparent",
          "border": "1.5px solid rgba(138,58,58,0.85)",
          "border-radius": "3px",
          "padding": "0 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#caa6a6",
          "border-bottom": "2px solid rgba(138,58,58,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "700"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#caa6a6",
          "background-color": "rgba(138,58,58,0.22)",
          "border-radius": "3px",
          "padding": "1px 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#caa6a6",
          "background": "linear-gradient(to top, rgba(138,58,58,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "700"
        }
      }
    ]
  }
}