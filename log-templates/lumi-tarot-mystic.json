{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-tarot-mystic",
  "name": "타로 미스틱",
  "description": "자정 보라와 금빛의 점성·타로 로그. 운명을 점치는 신비주의 카드 무드.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(165deg,#1a1230,#241640 55%,#180e2c)",
      "line-height": "1.78",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#d8c8f0",
      "border": "1px solid #4a3a6a",
      "border-radius": "10px",
      "padding": "28px",
      "box-shadow": "inset 0 0 0 1px rgba(212,175,90,.25), 0 16px 44px rgba(8,4,20,.5)",
      "font-family": "Georgia,'Noto Serif KR','Nanum Myeongjo',serif"
    },
    "header": {
      "color": "#d4af5a",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".28em",
      "text-align": "center",
      "padding": "0 0 14px",
      "margin": "0 0 18px",
      "border-bottom": "1px solid #4a3a6a"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#c8a8f0",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#9a7fc0",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#d4af5a",
        "border": "1px solid #b89548",
        "border-radius": "4px",
        "padding": "1px 7px",
        "font-size": "13px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#e8d0ff",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#b09ad0",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "☾운명☽",
    "style": {
      "color": "#1a1030",
      "background-color": "#d4af5a",
      "border-radius": "4px",
      "padding": "1px 9px",
      "font-weight": "700",
      "letter-spacing": ".05em"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#1a1030",
          "background-color": "#d4af5a",
          "border-radius": "4px",
          "padding": "1px 9px",
          "font-weight": "700",
          "letter-spacing": ".05em"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#d4af5a",
          "background-color": "transparent",
          "border": "1.5px solid rgba(212,175,90,0.85)",
          "border-radius": "4px",
          "padding": "0 7px",
          "font-weight": "700",
          "letter-spacing": ".05em"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#d4af5a",
          "border-bottom": "2px solid rgba(212,175,90,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "700",
          "letter-spacing": ".05em"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#d4af5a",
          "background-color": "rgba(212,175,90,0.22)",
          "border-radius": "4px",
          "padding": "1px 7px",
          "font-weight": "700",
          "letter-spacing": ".05em"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#d4af5a",
          "background": "linear-gradient(to top, rgba(212,175,90,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "700",
          "letter-spacing": ".05em"
        }
      }
    ]
  }
}