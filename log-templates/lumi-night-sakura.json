{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-night-sakura",
  "name": "밤벚꽃",
  "description": "어둠 속 조명 받은 벚꽃의 야경 로그. 다크 네이비에 번지는 분홍빛 정취.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(165deg,#16121e,#1e1626 55%,#241828)",
      "line-height": "1.86",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#ecd8e0",
      "border": "1px solid #3a2c3e",
      "border-radius": "12px",
      "padding": "28px",
      "box-shadow": "0 16px 42px rgba(10,6,14,.48)",
      "font-family": "'Nanum Myeongjo','Noto Serif KR',serif"
    },
    "header": {
      "color": "#f08ab0",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".22em",
      "text-shadow": "0 0 12px rgba(240,138,176,.4)",
      "padding": "0 0 13px",
      "margin": "0 0 17px",
      "border-bottom": "1px solid #3a2c3e"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#f8b0cc",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#a888b8",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#c89ad8",
        "border": "1px solid #4a3a52",
        "border-radius": "6px",
        "padding": "1px 7px",
        "font-size": "13px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#ffe0ec",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#c0a8c0",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "그 사람",
    "style": {
      "color": "#1a1018",
      "background-color": "#f08ab0",
      "border-radius": "999px",
      "padding": "1px 9px",
      "font-weight": "700"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#1a1018",
          "background-color": "#f08ab0",
          "border-radius": "999px",
          "padding": "1px 9px",
          "font-weight": "700"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#f08ab0",
          "background-color": "transparent",
          "border": "1.5px solid rgba(240,138,176,0.85)",
          "border-radius": "999px",
          "padding": "0 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#f08ab0",
          "border-bottom": "2px solid rgba(240,138,176,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "700"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#f08ab0",
          "background-color": "rgba(240,138,176,0.22)",
          "border-radius": "7px",
          "padding": "1px 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#f08ab0",
          "background": "linear-gradient(to top, rgba(240,138,176,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "700"
        }
      }
    ]
  }
}