{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-citypop-sunset",
  "name": "시티팝 선셋",
  "description": "마젠타-인디고 그라데이션과 청록 네온. 80년대 시티팝 레트로퓨처 로그.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(165deg,#2a1838,#3a1a4a 45%,#5a2050)",
      "line-height": "1.78",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#f0d8f0",
      "border": "1px solid #6a3a7a",
      "border-radius": "16px",
      "padding": "26px",
      "box-shadow": "0 16px 44px rgba(20,8,32,.45)",
      "font-family": "-apple-system,BlinkMacSystemFont,'Noto Sans KR',sans-serif"
    },
    "header": {
      "color": "#ff8ae0",
      "font-size": "12px",
      "font-weight": "800",
      "letter-spacing": ".2em",
      "text-shadow": "0 0 12px rgba(74,214,224,.5)",
      "padding": "0 0 12px",
      "margin": "0 0 16px",
      "border-bottom": "1px solid #6a3a7a"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#ffb0e8",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#6ad0e0",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#4ad6e0",
        "border": "1px solid #3aa8b8",
        "border-radius": "7px",
        "padding": "1px 7px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#fff0fa",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#d0a0d8",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "★게스트★",
    "style": {
      "color": "#2a0a28",
      "background-color": "#ff6ad5",
      "border-radius": "999px",
      "padding": "1px 9px",
      "font-weight": "800"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#2a0a28",
          "background-color": "#ff6ad5",
          "border-radius": "999px",
          "padding": "1px 9px",
          "font-weight": "800"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#ff6ad5",
          "background-color": "transparent",
          "border": "1.5px solid rgba(255,106,213,0.85)",
          "border-radius": "999px",
          "padding": "0 7px",
          "font-weight": "800"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#ff6ad5",
          "border-bottom": "2px solid rgba(255,106,213,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "800"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#ff6ad5",
          "background-color": "rgba(255,106,213,0.22)",
          "border-radius": "7px",
          "padding": "1px 7px",
          "font-weight": "800"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#ff6ad5",
          "background": "linear-gradient(to top, rgba(255,106,213,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "800"
        }
      }
    ]
  }
}