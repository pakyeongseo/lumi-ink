{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-grandfather-clock",
  "name": "그랜드파더 클락",
  "description": "월넛 가구와 황동 시계판의 앤틱 괘종시계 로그. 녹청 스팀펑크나 가죽 도서관과 달리 따뜻한 월넛·황동 톤.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(160deg,#241710,#2e1e14 55%,#26190f)",
      "color": "#c8b292",
      "border": "2px solid #a8853e",
      "border-radius": "6px",
      "padding": "28px 26px",
      "box-shadow": "0 18px 46px rgba(0,0,0,.5), inset 0 0 60px rgba(120,86,34,.18)",
      "font-family": "Georgia,'Noto Serif KR','Nanum Myeongjo',serif",
      "line-height": "1.9",
      "max-width": "720px",
      "margin": "0 auto"
    },
    "header": {
      "color": "#d6a850",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".32em",
      "text-align": "center",
      "border-bottom": "1px solid #6e5428",
      "padding": "0 0 15px",
      "margin": "0 0 20px"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 13px"
    },
    "empty": {
      "height": "12px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#ecdcb8",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#a08a64",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#d6a850",
        "border": "1px solid #856534",
        "border-radius": "3px",
        "padding": "1px 8px",
        "font-size": "13px",
        "letter-spacing": ".05em"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#e6c47e",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#9a8460",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "그 사람",
    "style": {
      "color": "#241710",
      "background-color": "#d6a850",
      "border-radius": "2px",
      "padding": "1px 8px",
      "font-weight": "700"
    }
  }
}