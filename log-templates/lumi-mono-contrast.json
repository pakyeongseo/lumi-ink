{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-mono-contrast",
  "name": "모노 컨트라스트",
  "description": "순백과 순흑의 강렬한 대비 로그.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background-color": "#ffffff",
      "color": "#111111",
      "border": "2px solid #111111",
      "border-radius": "3px",
      "padding": "28px 26px",
      "box-shadow": "8px 8px 0 #111111",
      "font-family": "-apple-system,BlinkMacSystemFont,'Noto Sans KR','Segoe UI',sans-serif",
      "line-height": "1.78",
      "max-width": "700px",
      "margin": "0 auto"
    },
    "header": {
      "color": "#000000",
      "font-size": "13px",
      "font-weight": "800",
      "letter-spacing": ".26em",
      "border-bottom": "3px solid #000000",
      "padding": "0 0 13px",
      "margin": "0 0 18px"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#000000",
        "font-weight": "800"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#8a8a8a",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#ffffff",
        "background-color": "#111111",
        "border-radius": "2px",
        "padding": "1px 8px",
        "font-size": "13px",
        "font-weight": "700",
        "letter-spacing": ".06em"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#000000",
        "font-weight": "800",
        "border-bottom": "2px solid #000000"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#5a5a5a",
        "font-style": "italic"
      }
    },
    {
      "id": "dqq",
      "label": "큰따옴표 기호",
      "pattern": "\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#808080"
      }
    },
    {
      "id": "sqq",
      "label": "작은따옴표 기호",
      "pattern": "'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#c4c4c4"
      }
    }
  ],
  "persona": {
    "maskText": "X",
    "style": {
      "color": "#ffffff",
      "background-color": "#000000",
      "border-radius": "0",
      "padding": "1px 9px",
      "font-weight": "800",
      "letter-spacing": ".08em"
    }
  }
}