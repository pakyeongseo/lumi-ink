{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-macaron",
  "name": "마카롱 디저트",
  "description": "파스텔 핑크와 민트, 초콜릿의 달콤한 카페 로그. 둥글고 부드러운 무드.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(160deg,#fdf0f4,#f6e8f0 60%,#eef4ec)",
      "line-height": "1.8",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#6a5260",
      "border": "1px solid #f0d0dc",
      "border-radius": "20px",
      "padding": "26px",
      "box-shadow": "0 12px 36px rgba(200,140,170,.18)",
      "font-family": "'Quicksand','Noto Sans KR',sans-serif"
    },
    "header": {
      "color": "#d878a0",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".14em",
      "padding": "0 0 12px",
      "margin": "0 0 16px",
      "border-bottom": "1px solid #f2d6e0"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#d06a96",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#7ab0a8",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#5aa898",
        "background-color": "rgba(138,208,192,.18)",
        "border-radius": "9px",
        "padding": "1px 7px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#b04a78",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#b09aa8",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "♡비밀♡",
    "style": {
      "color": "#ffffff",
      "background-color": "#e891b0",
      "border-radius": "999px",
      "padding": "1px 9px",
      "font-weight": "700"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#ffffff",
          "background-color": "#e891b0",
          "border-radius": "999px",
          "padding": "1px 9px",
          "font-weight": "700"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#8b576a",
          "background-color": "transparent",
          "border": "1.5px solid rgba(232,145,176,0.85)",
          "border-radius": "999px",
          "padding": "0 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#8b576a",
          "border-bottom": "2px solid rgba(232,145,176,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "700"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#8b576a",
          "background-color": "rgba(232,145,176,0.16)",
          "border-radius": "7px",
          "padding": "1px 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#8b576a",
          "background": "linear-gradient(to top, rgba(232,145,176,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "700"
        }
      }
    ]
  }
}