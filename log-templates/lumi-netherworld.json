{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-netherworld",
  "name": "명계 저승",
  "description": "창백한 보라와 저승 청록의 사후세계 로그. 망자가 거니는 명부의 무드.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(165deg,#1a1426,#120e1c)",
      "line-height": "1.78",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#c8c0d0",
      "border": "1px solid #342a44",
      "border-radius": "8px",
      "padding": "28px",
      "box-shadow": "inset 0 0 50px rgba(74,168,144,.08), 0 16px 42px rgba(6,4,10,.5)",
      "font-family": "'Nanum Myeongjo','Noto Serif KR',serif"
    },
    "header": {
      "color": "#8a6ad0",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".24em",
      "padding": "0 0 12px",
      "margin": "0 0 16px",
      "border-bottom": "1px solid #342a44"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#b098e0",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#4aa890",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#4aa890",
        "border": "1px solid #2e5a4e",
        "border-radius": "3px",
        "padding": "1px 7px",
        "font-size": "13px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#ded0f0",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#9a8ab0",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "망자",
    "style": {
      "color": "#120e1c",
      "background-color": "#8a6ad0",
      "border-radius": "3px",
      "padding": "1px 9px",
      "font-weight": "700"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#120e1c",
          "background-color": "#8a6ad0",
          "border-radius": "3px",
          "padding": "1px 9px",
          "font-weight": "700"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#cabcea",
          "background-color": "transparent",
          "border": "1.5px solid rgba(138,106,208,0.85)",
          "border-radius": "3px",
          "padding": "0 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#cabcea",
          "border-bottom": "2px solid rgba(138,106,208,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "700"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#cabcea",
          "background-color": "rgba(138,106,208,0.22)",
          "border-radius": "3px",
          "padding": "1px 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#cabcea",
          "background": "linear-gradient(to top, rgba(138,106,208,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "700"
        }
      }
    ]
  }
}