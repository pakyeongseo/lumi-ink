{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-mars-colony",
  "name": "화성 식민지",
  "description": "붉은 먼지와 청록 HUD의 화성 개척 로그. 척박한 외계 행성의 SF 무드.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(165deg,#3a1c12,#2a140c)",
      "line-height": "1.78",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#f0d0b8",
      "border": "1px solid #6a3422",
      "border-radius": "6px",
      "padding": "26px",
      "box-shadow": "inset 0 0 0 1px rgba(74,208,192,.1), 0 16px 42px rgba(14,6,2,.5)",
      "font-family": "'Space Mono','SFMono-Regular',Consolas,'D2Coding',monospace"
    },
    "header": {
      "color": "#e8703a",
      "font-size": "12px",
      "font-weight": "800",
      "letter-spacing": ".18em",
      "padding": "0 0 12px",
      "margin": "0 0 16px",
      "text-transform": "uppercase",
      "border-bottom": "1px dashed #6a3422"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#f09a6a",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#4ad0c0",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#4ad0c0",
        "border": "1px solid #2a7a72",
        "border-radius": "2px",
        "padding": "1px 6px",
        "font-size": "13px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#ffe0c8",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#c8a088",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "[대원]",
    "style": {
      "color": "#2a140c",
      "background-color": "#e8703a",
      "border-radius": "2px",
      "padding": "1px 8px",
      "font-weight": "700"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#2a140c",
          "background-color": "#e8703a",
          "border-radius": "2px",
          "padding": "1px 8px",
          "font-weight": "700"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#f5bfa6",
          "background-color": "transparent",
          "border": "1.5px solid rgba(232,112,58,0.85)",
          "border-radius": "2px",
          "padding": "0 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#f5bfa6",
          "border-bottom": "2px solid rgba(232,112,58,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "700"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#f5bfa6",
          "background-color": "rgba(232,112,58,0.22)",
          "border-radius": "2px",
          "padding": "1px 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#f5bfa6",
          "background": "linear-gradient(to top, rgba(232,112,58,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "700"
        }
      }
    ]
  }
}