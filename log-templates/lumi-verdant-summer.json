{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-verdant-summer",
  "name": "버던트 서머",
  "description": "짙은 숲 그늘과 에메랄드의 여름 녹음 로그.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(160deg,#18260e,#1f3214 55%,#192a10)",
      "color": "#a8c6a8",
      "border": "1px solid #45662a",
      "border-radius": "12px",
      "padding": "28px 26px",
      "box-shadow": "0 18px 44px rgba(6,16,10,.5), inset 0 0 60px rgba(40,110,60,.12)",
      "font-family": "-apple-system,BlinkMacSystemFont,'Noto Sans KR','Segoe UI',sans-serif",
      "line-height": "1.88",
      "max-width": "720px",
      "margin": "0 auto"
    },
    "header": {
      "color": "#a6d84a",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".3em",
      "text-align": "center",
      "border-bottom": "1px solid #2a4e34",
      "padding": "0 0 14px",
      "margin": "0 0 18px"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 13px"
    },
    "empty": {
      "height": "12px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#9ee87a",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#6fb89a",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#6fc488",
        "border": "1px solid #3a6e4a",
        "border-radius": "6px",
        "padding": "1px 8px",
        "font-size": "13px",
        "letter-spacing": ".04em"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#c2f0a0",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#7fa882",
        "font-style": "italic"
      }
    },
    {
      "id": "dqq",
      "label": "큰따옴표 기호",
      "pattern": "\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#5c8a45"
      }
    },
    {
      "id": "sqq",
      "label": "작은따옴표 기호",
      "pattern": "'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#447255"
      }
    }
  ],
  "persona": {
    "maskText": "그 사람",
    "style": {
      "color": "#13241a",
      "background-color": "#6fc46a",
      "border-radius": "999px",
      "padding": "1px 9px",
      "font-weight": "700"
    }
  }
}