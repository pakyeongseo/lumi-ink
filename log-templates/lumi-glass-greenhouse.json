{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-glass-greenhouse",
  "name": "유리 온실",
  "description": "햇빛 가득한 화이트 유리 온실 로그. 세이지 그린 식물과 투명한 빛의 정원.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(160deg,#f0f6f0,#e6f0ea)",
      "line-height": "1.8",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#3a4a3e",
      "border": "1px solid #c4d6c8",
      "border-radius": "14px",
      "padding": "28px",
      "box-shadow": "0 12px 34px rgba(80,120,90,.12)",
      "font-family": "-apple-system,BlinkMacSystemFont,'Noto Sans KR',sans-serif"
    },
    "header": {
      "color": "#4a9a7a",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".16em",
      "border-bottom": "1px solid #bcd4c2",
      "padding": "0 0 12px",
      "margin": "0 0 16px"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#2e8a64",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#7a9a84",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#4a9a7a",
        "background-color": "rgba(74,154,122,.12)",
        "border-radius": "8px",
        "padding": "1px 7px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#2a3a2e",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#6a8a74",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "정원사",
    "style": {
      "color": "#f0f6f0",
      "background-color": "#4a9a7a",
      "border-radius": "999px",
      "padding": "1px 9px",
      "font-weight": "700"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#f0f6f0",
          "background-color": "#4a9a7a",
          "border-radius": "999px",
          "padding": "1px 9px",
          "font-weight": "700"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#4a9a7a",
          "background-color": "transparent",
          "border": "1.5px solid rgba(74,154,122,0.85)",
          "border-radius": "999px",
          "padding": "0 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#4a9a7a",
          "border-bottom": "2px solid rgba(74,154,122,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "700"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#4a9a7a",
          "background-color": "rgba(74,154,122,0.16)",
          "border-radius": "7px",
          "padding": "1px 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#4a9a7a",
          "background": "linear-gradient(to top, rgba(74,154,122,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "700"
        }
      }
    ]
  }
}