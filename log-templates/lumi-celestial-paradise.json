{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-celestial-paradise",
  "name": "천상 낙원",
  "description": "밝은 금빛과 하늘색의 신성한 낙원 로그. 빛이 쏟아지는 천상의 무드.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(180deg,#eef4fb,#e4eef8 60%,#f6f0e8)",
      "line-height": "1.82",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#4a5260",
      "border": "1px solid #d6e0ec",
      "border-radius": "16px",
      "padding": "28px",
      "box-shadow": "inset 0 30px 60px rgba(212,168,56,.08), 0 12px 34px rgba(140,160,200,.16)",
      "font-family": "Georgia,'Noto Serif KR','Nanum Myeongjo',serif"
    },
    "header": {
      "color": "#c89a30",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".2em",
      "padding": "0 0 12px",
      "margin": "0 0 16px",
      "text-align": "center",
      "border-bottom": "1px solid #dcc89a"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#5a8ac0",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#9a8a6a",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#c89a30",
        "border": "1px solid #dcc89a",
        "border-radius": "8px",
        "padding": "1px 7px",
        "font-size": "13px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#3a4250",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#7a8290",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "방문자",
    "style": {
      "color": "#fbf8f0",
      "background-color": "#d4a838",
      "border-radius": "999px",
      "padding": "1px 9px",
      "font-weight": "700"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#fbf8f0",
          "background-color": "#d4a838",
          "border-radius": "999px",
          "padding": "1px 9px",
          "font-weight": "700"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#7f6522",
          "background-color": "transparent",
          "border": "1.5px solid rgba(212,168,56,0.85)",
          "border-radius": "999px",
          "padding": "0 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#7f6522",
          "border-bottom": "2px solid rgba(212,168,56,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "700"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#7f6522",
          "background-color": "rgba(212,168,56,0.16)",
          "border-radius": "7px",
          "padding": "1px 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#7f6522",
          "background": "linear-gradient(to top, rgba(212,168,56,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "700"
        }
      }
    ]
  }
}