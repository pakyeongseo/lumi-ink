{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-grimoire",
  "name": "그리모어",
  "description": "암갈색 가죽과 에메랄드·금박의 연금술 마도서. 비전 지식이 적힌 고서 무드.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(160deg,#241c14,#1a140e)",
      "line-height": "1.85",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#cdbfa0",
      "border": "1px solid #4a3a26",
      "border-radius": "5px",
      "padding": "30px 28px",
      "box-shadow": "inset 0 0 0 1px rgba(200,154,74,.2), 0 16px 40px rgba(8,4,2,.5)",
      "font-family": "Georgia,'Noto Serif KR','Nanum Myeongjo',serif"
    },
    "header": {
      "color": "#c89a4a",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".2em",
      "text-align": "center",
      "border-bottom": "1px solid #4a3a26",
      "padding": "0 0 14px",
      "margin": "0 0 18px"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#6ec8a0",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#9a8a6a",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#c89a4a",
        "border": "1px solid #8a6a36",
        "border-radius": "3px",
        "padding": "1px 7px",
        "font-size": "13px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#e8d0a0",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#a89878",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "이름 없는 자",
    "style": {
      "color": "#1a140e",
      "background-color": "#4ea882",
      "border-radius": "3px",
      "padding": "1px 9px",
      "font-weight": "700"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#1a140e",
          "background-color": "#4ea882",
          "border-radius": "3px",
          "padding": "1px 9px",
          "font-weight": "700"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#afd8c7",
          "background-color": "transparent",
          "border": "1.5px solid rgba(78,168,130,0.85)",
          "border-radius": "3px",
          "padding": "0 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#afd8c7",
          "border-bottom": "2px solid rgba(78,168,130,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "700"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#afd8c7",
          "background-color": "rgba(78,168,130,0.22)",
          "border-radius": "3px",
          "padding": "1px 7px",
          "font-weight": "700"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#afd8c7",
          "background": "linear-gradient(to top, rgba(78,168,130,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "700"
        }
      }
    ]
  }
}