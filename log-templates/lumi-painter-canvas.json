{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-painter-canvas",
  "name": "페인터 캔버스",
  "description": "아이보리 캔버스와 유화 물감색의 화가 로그.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background-color": "#f6f1e4",
      "color": "#4a443a",
      "border": "6px solid #cdbf9e",
      "border-radius": "3px",
      "padding": "26px 24px",
      "box-shadow": "0 16px 40px rgba(90,80,60,.2), inset 0 0 0 1px rgba(120,108,82,.2)",
      "font-family": "Georgia,'Noto Serif KR','Nanum Myeongjo',serif",
      "line-height": "1.88",
      "max-width": "720px",
      "margin": "0 auto"
    },
    "header": {
      "color": "#5a5448",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".24em",
      "border-bottom": "1px solid #d2c6a8",
      "padding": "0 0 14px",
      "margin": "0 0 18px"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 13px"
    },
    "empty": {
      "height": "12px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#2f5aa8",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#b0623a",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#8a6a24",
        "background-color": "rgba(220,190,110,.32)",
        "border-radius": "4px",
        "padding": "1px 8px",
        "font-size": "13px",
        "letter-spacing": ".03em"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#b0322e",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#6e7a48",
        "font-style": "italic"
      }
    },
    {
      "id": "dqq",
      "label": "큰따옴표 기호",
      "pattern": "\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#92a6c6"
      }
    },
    {
      "id": "sqq",
      "label": "작은따옴표 기호",
      "pattern": "'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#d3aa8f"
      }
    }
  ],
  "persona": {
    "maskText": "그 사람",
    "style": {
      "color": "#f6f1e4",
      "background-color": "#3a5fa0",
      "border-radius": "3px",
      "padding": "1px 8px",
      "font-weight": "700"
    }
  }
}