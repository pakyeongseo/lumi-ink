{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-pulp-scifi",
  "name": "펄프 SF",
  "description": "빛바랜 크림과 레트로 오렌지의 50년대 SF 잡지 로그. 펄프 사이파이 무드.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(160deg,#e8e0cc,#dcd2b8)",
      "line-height": "1.76",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#2a2e3a",
      "border": "1px solid #c4b894",
      "border-radius": "4px",
      "padding": "28px",
      "box-shadow": "0 12px 32px rgba(110,90,50,.16)",
      "font-family": "Georgia,'Noto Serif KR','Nanum Myeongjo',serif"
    },
    "header": {
      "color": "#d8542a",
      "font-size": "12px",
      "font-weight": "800",
      "letter-spacing": ".18em",
      "padding": "0 0 12px",
      "margin": "0 0 16px",
      "text-transform": "uppercase",
      "border-bottom": "3px double #2a8a9a"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#b8401f",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#5a6a72",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#2a8a9a",
        "border": "1px solid #6aa0a8",
        "border-radius": "2px",
        "padding": "1px 7px",
        "font-size": "13px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#1a1e2a",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#5a5e6a",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "[지구인]",
    "style": {
      "color": "#ece4d0",
      "background-color": "#d8542a",
      "border-radius": "2px",
      "padding": "1px 9px",
      "font-weight": "800"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#ece4d0",
          "background-color": "#d8542a",
          "border-radius": "2px",
          "padding": "1px 9px",
          "font-weight": "800"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#d8542a",
          "background-color": "transparent",
          "border": "1.5px solid rgba(216,84,42,0.85)",
          "border-radius": "2px",
          "padding": "0 7px",
          "font-weight": "800"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#d8542a",
          "border-bottom": "2px solid rgba(216,84,42,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "800"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#d8542a",
          "background-color": "rgba(216,84,42,0.16)",
          "border-radius": "2px",
          "padding": "1px 7px",
          "font-weight": "800"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#d8542a",
          "background": "linear-gradient(to top, rgba(216,84,42,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "800"
        }
      }
    ]
  }
}