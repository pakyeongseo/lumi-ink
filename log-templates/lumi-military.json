{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-military",
  "name": "밀리터리 브리핑",
  "description": "올리브 카키와 앰버 모노의 작전 보고서. 전술 브리핑 무드의 로그.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(#1a1e14,#161a10)",
      "line-height": "1.78",
      "max-width": "740px",
      "margin": "0 auto",
      "white-space": "normal",
      "color": "#c0c8a8",
      "border": "1px solid #3a4226",
      "border-radius": "2px",
      "padding": "24px",
      "box-shadow": "inset 0 0 0 1px rgba(184,160,64,.1)",
      "font-family": "'Space Mono','SFMono-Regular',Consolas,'D2Coding',monospace"
    },
    "header": {
      "color": "#d0b850",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".2em",
      "text-transform": "uppercase",
      "border-bottom": "1px dashed #4a5230",
      "padding": "0 0 12px",
      "margin": "0 0 16px"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 12px"
    },
    "empty": {
      "height": "11px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#d8c060",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#8a946a",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#b8a040",
        "border": "1px solid #6a6a36",
        "border-radius": "2px",
        "padding": "1px 6px",
        "font-size": "13px"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#f0e0a0",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#9aa078",
        "font-style": "italic"
      }
    }
  ],
  "persona": {
    "maskText": "[기밀해제요]",
    "style": {
      "color": "#161a10",
      "background-color": "#b8a040",
      "border-radius": "2px",
      "padding": "1px 8px",
      "font-weight": "700",
      "letter-spacing": ".05em"
    },
    "designs": [
      {
        "label": "솔리드 칩",
        "style": {
          "color": "#161a10",
          "background-color": "#b8a040",
          "border-radius": "2px",
          "padding": "1px 8px",
          "font-weight": "700",
          "letter-spacing": ".05em"
        }
      },
      {
        "label": "아웃라인",
        "style": {
          "color": "#b8a040",
          "background-color": "transparent",
          "border": "1.5px solid rgba(184,160,64,0.85)",
          "border-radius": "2px",
          "padding": "0 7px",
          "font-weight": "700",
          "letter-spacing": ".05em"
        }
      },
      {
        "label": "언더라인",
        "style": {
          "color": "#b8a040",
          "border-bottom": "2px solid rgba(184,160,64,0.9)",
          "padding": "0 1px 1px",
          "font-weight": "700",
          "letter-spacing": ".05em"
        }
      },
      {
        "label": "소프트 틴트",
        "style": {
          "color": "#b8a040",
          "background-color": "rgba(184,160,64,0.22)",
          "border-radius": "2px",
          "padding": "1px 7px",
          "font-weight": "700",
          "letter-spacing": ".05em"
        }
      },
      {
        "label": "마커 하이라이트",
        "style": {
          "color": "#b8a040",
          "background": "linear-gradient(to top, rgba(184,160,64,0.42) 42%, transparent 42%)",
          "padding": "0 3px",
          "font-weight": "700",
          "letter-spacing": ".05em"
        }
      }
    ]
  }
}