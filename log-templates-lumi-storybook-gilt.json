{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-storybook-gilt",
  "name": "스토리북 길트",
  "description": "따뜻한 크림과 금별의 동화책 로그.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(160deg,#fdf3df,#faecc8 55%,#f6e8d0)",
      "color": "#5a4d44",
      "border": "1px solid #e6cf9a",
      "border-radius": "18px",
      "padding": "28px 26px",
      "box-shadow": "0 16px 42px rgba(180,150,90,.18), inset 0 0 60px rgba(255,240,210,.4)",
      "font-family": "Georgia,'Noto Serif KR','Nanum Myeongjo',serif",
      "line-height": "1.9",
      "max-width": "720px",
      "margin": "0 auto"
    },
    "header": {
      "color": "#b88a30",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".28em",
      "text-align": "center",
      "border-bottom": "2px dotted #e8d2a0",
      "padding": "0 0 14px",
      "margin": "0 0 18px"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 13px"
    },
    "empty": {
      "height": "12px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#c86a3e",
        "font-weight": "700"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#8878b8",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(마법·장면)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#a8802e",
        "background-color": "rgba(240,210,140,.4)",
        "border-radius": "10px",
        "padding": "1px 8px",
        "font-size": "13px",
        "font-weight": "700",
        "letter-spacing": ".03em"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#9a6a2e",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#8a8a4e",
        "font-style": "italic"
      }
    },
    {
      "id": "dqq",
      "label": "큰따옴표 기호",
      "pattern": "\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#e0ac88"
      }
    },
    {
      "id": "sqq",
      "label": "작은따옴표 기호",
      "pattern": "'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#c0b2c5"
      }
    }
  ],
  "persona": {
    "maskText": "그 아이",
    "style": {
      "color": "#fdf6e6",
      "background-color": "#d8a838",
      "border-radius": "999px",
      "padding": "1px 9px",
      "font-weight": "700"
    }
  }
}