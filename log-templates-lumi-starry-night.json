{
  "kind": "lumink-log-template",
  "schemaVersion": 1,
  "id": "lumi-starry-night",
  "name": "스타리 나이트",
  "description": "인디고 밤하늘과 금빛 별의 낭만 로그.",
  "author": "Anamel",
  "styles": {
    "canvas": {
      "background": "linear-gradient(160deg,#0e1432,#141c46 55%,#10163a)",
      "color": "#c2c8e6",
      "border": "1px solid #8a7440",
      "border-radius": "14px",
      "padding": "28px 26px",
      "box-shadow": "0 0 0 1px rgba(220,190,110,.12), 0 20px 50px rgba(4,8,24,.55), inset 0 0 70px rgba(80,90,180,.12)",
      "font-family": "Georgia,'Noto Serif KR','Nanum Myeongjo',serif",
      "line-height": "1.9",
      "max-width": "720px",
      "margin": "0 auto"
    },
    "header": {
      "color": "#e6cd84",
      "font-size": "12px",
      "font-weight": "700",
      "letter-spacing": ".32em",
      "text-align": "center",
      "border-bottom": "1px solid #3a3a5e",
      "padding": "0 0 15px",
      "margin": "0 0 20px"
    },
    "body": {
      "white-space": "pre-wrap",
      "overflow-wrap": "anywhere"
    },
    "paragraph": {
      "margin": "0 0 13px"
    },
    "empty": {
      "height": "12px"
    }
  },
  "rules": [
    {
      "id": "dq",
      "label": "큰따옴표(대사)",
      "pattern": "\"([^\"\\n]+)\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#f0e4c2",
        "font-weight": "700",
        "box-shadow": "0 0 14px rgba(240,224,160,.18)"
      }
    },
    {
      "id": "sq",
      "label": "작은따옴표(속마음)",
      "pattern": "'([^'\\n]+)'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#a99cd6",
        "font-style": "italic"
      }
    },
    {
      "id": "br",
      "label": "대괄호(상황)",
      "pattern": "\\[([^\\]\\n]+)\\]",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#e6cd84",
        "border": "1px solid #7a663a",
        "border-radius": "6px",
        "padding": "1px 8px",
        "font-size": "13px",
        "letter-spacing": ".05em",
        "box-shadow": "0 0 12px rgba(220,190,110,.25)"
      }
    },
    {
      "id": "b",
      "label": "굵게",
      "pattern": "\\*\\*([^*\\n]+)\\*\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#f2db90",
        "font-weight": "800"
      }
    },
    {
      "id": "i",
      "label": "기울임",
      "pattern": "\\*([^*\\n]+)\\*",
      "flags": "g",
      "capture": 1,
      "stripDelimiters": true,
      "style": {
        "color": "#b0a4d8",
        "font-style": "italic"
      }
    },
    {
      "id": "dqq",
      "label": "큰따옴표 기호",
      "pattern": "\"",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#807e7e"
      }
    },
    {
      "id": "sqq",
      "label": "작은따옴표 기호",
      "pattern": "'",
      "flags": "g",
      "capture": 0,
      "stripDelimiters": false,
      "style": {
        "color": "#5c5a88"
      }
    }
  ],
  "persona": {
    "maskText": "그 사람",
    "style": {
      "color": "#0e1432",
      "background-color": "#e6cd84",
      "border-radius": "999px",
      "padding": "1px 9px",
      "font-weight": "700",
      "box-shadow": "0 0 12px rgba(230,205,132,.5)"
    }
  }
}